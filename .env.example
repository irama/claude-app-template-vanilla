# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (if used)
# NEXT_PUBLIC_SUPABASE_URL=your-project-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry error monitoring (docs/production-playbook.md — wire per project)
# Create project at sentry.io → Settings → Projects → <project> → Client Keys (DSN).
# Leave empty locally (SDK no-ops); set in Vercel for Preview + Production.
NEXT_PUBLIC_SENTRY_DSN=

# Add project-specific variables below
